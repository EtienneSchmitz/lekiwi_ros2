<?xml version="1.0"?>
<model>
  <name>aruco_cube</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Bootcamp ROS 2</name>
  </author>
  <description>
    Cube a saisir de 4 cm portant un marqueur ArUco (dict 4x4_50) sur sa face
    superieure. Couvre la detection ArUco : pose 6D + classe = ID du marqueur.
    Texture par defaut : aruco_0.png. Le script spawn_object.py substitue le PNG
    selon le parametre aruco_id. Regenerer un PNG : scripts/generate_aruco.py.
  </description>
</model>
