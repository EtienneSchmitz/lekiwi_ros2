<?xml version="1.0"?>
<model>
  <name>pick_cube</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Bootcamp ROS 2</name>
  </author>
  <description>
    Cube a saisir de 4 cm (rouge par defaut). Objet generique du projet Jour 5 :
    detection couleur (HSV), classe par couleur. Le script spawn_object.py genere
    les variantes de couleur a la volee ; ce model.sdf est la version rouge de base.
  </description>
</model>
